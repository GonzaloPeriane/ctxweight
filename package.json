{
  "name": "ctxweight",
  "version": "0.1.0",
  "description": "X-ray your AI agent's context — health and token cost in one command.",
  "type": "module",
  "bin": {
    "ctxweight": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test:secrets": "tsx scripts/test-secrets.ts",
    "study": "tsx scripts/study/run-study.ts",
    "study:aggregate": "tsx scripts/study/aggregate.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GonzaloPeriane/ctxweight.git"
  },
  "homepage": "https://github.com/GonzaloPeriane/ctxweight#readme",
  "bugs": {
    "url": "https://github.com/GonzaloPeriane/ctxweight/issues"
  },
  "keywords": [
    "ai",
    "claude",
    "agents",
    "context-engineering",
    "agents-md",
    "claude-md",
    "tokens",
    "mcp",
    "cli",
    "linter",
    "context-weight"
  ],
  "author": "GonzaloPeriane",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0"
  }
}
